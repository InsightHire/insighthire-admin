# Application
NODE_ENV=production
PORT=3000

# Public URLs (build-time variables)
NEXT_PUBLIC_APP_URL=https://admin.insighthire.com
NEXT_PUBLIC_API_URL=https://api.insighthire.com
NEXT_PUBLIC_TRPC_URL=https://api.insighthire.com/trpc

# Optional: Database (only if making direct queries)
# DATABASE_URL=postgresql://...

# ─── Authio (authio.com) — Microsoft 365 admin sign-in ───────────────────────
# Project ID is exposed to the browser via the hosted-UI redirect URL; safe to
# commit per Authio docs. Secret key stays server-side (admin app doesn't need it;
# only the API does — set there).
AUTHIO_PROJECT_ID=proj_...
# Management API host — REST user lookups only. Does NOT sign tokens or serve JWKS.
AUTHIO_API_URL=https://api.authio.com
AUTHIO_HOSTED_UI_URL=https://auth.insighthire.com
# Auth-core host — signs access tokens (EdDSA) and serves the JWKS. The token `iss`
# claim is this host, so JWKS + issuer derive from here (NOT from AUTHIO_API_URL).
AUTHIO_AUTH_CORE_URL=https://identity.authio.com
# Org pinned on the sign-in URL so users skip the method picker and go
# straight to Entra. Defaults to InsightHire's org id if unset.
AUTHIO_ORGANIZATION_ID=org_h8k2m9qx4n1v7p3r6w5t0

# ─── SP-initiated SSO (preferred — zero Authio UI) ─────────────────────────
# When AUTHIO_SSO_CONNECTION_ID is set, the sign-in handler bypasses the hosted UI
# entirely and redirects straight to the IdP via:
#   https://sso.authio.com/v1/sso/connections/{conn_id}/initiate?…
# The connection id is on the org's Features → Single Sign-On card in the
# Authio dashboard (the One-click Microsoft connection emits an `sso_…` id).
# Without this set, sign-in falls back to AUTHIO_HOSTED_UI_URL (auth.insighthire.com).
# Copy from Authio dashboard → Org → Features → Single Sign-On (sso_… id).
# AUTHIO_SSO_CONNECTION_ID=sso_...
# AUTHIO_SSO_HOST=https://sso.authio.com

# Auth-core calls from the BFF send X-Authio-SDK: nextjs/0.3.2 automatically
# (no env var needed). HQ uses this to attribute SDK version per customer.

# Optional explicit overrides — defaults below are derived from AUTHIO_AUTH_CORE_URL.
# AUTHIO_JWKS_URL=https://identity.authio.com/v1/auth/.well-known/jwks.json
# AUTHIO_JWT_ISSUER=https://identity.authio.com
# AUTHIO_JWT_AUDIENCE=authio
