# Application
NODE_ENV=production
PORT=3000

# Public URLs (build-time variables)
NEXT_PUBLIC_APP_URL=https://admin.insighthire.com
NEXT_PUBLIC_API_URL=https://api.insighthire.com
NEXT_PUBLIC_TRPC_URL=https://api.insighthire.com/trpc

# Optional: Database (only if making direct queries)
# DATABASE_URL=postgresql://...

# ─── Authio (authio.com) — Microsoft 365 admin sign-in ───────────────────────
# Project ID is exposed to the browser via the hosted-UI redirect URL; safe to
# commit per Authio docs. Secret key stays server-side (admin app doesn't need it;
# only the API does — set there).
AUTHIO_PROJECT_ID=proj_...
AUTHIO_API_URL=https://api.authio.com
AUTHIO_HOSTED_UI_URL=https://lobby.authio.com
# Optional overrides — only if Authio routes JWKS / issuer through a different host.
# AUTHIO_JWKS_URL=https://api.authio.com/.well-known/jwks.json
# AUTHIO_JWT_ISSUER=https://api.authio.com
# AUTHIO_JWT_AUDIENCE=authio
